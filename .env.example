# Shared login for all users
AUTH_LOGIN=admin
AUTH_PASSWORD=change-me
# HMAC key for session cookie, e.g. `openssl rand -hex 32`
SESSION_SECRET=
# Proxy for yt-dlp, YouTube API and yt-dlp self-update. Empty = direct.
PROXY_URL=socks5h://host.docker.internal:10808
# YouTube Data API key (optional) — enables "playlist added date" tags
GOOGLE_API_KEY=
# How long finished job files live (Go duration: 1h, 30m, 24h)
FILE_TTL=1h
MAX_CONCURRENT_JOBS=2
PORT=8080
DATA_DIR=/data
# Optional: path (inside the container) to a Netscape cookies.txt for YouTube.
# Put the file at ./cookies/cookies.txt on the host and set:
# COOKIES_FILE=/cookies/cookies.txt
COOKIES_FILE=
SUBDOMAIN=
DOMAIN=
